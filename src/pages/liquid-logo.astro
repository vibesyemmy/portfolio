---
import Layout from '../layouts/Layout.astro';

const CONTROLS = [
  { key: 'warmth', label: 'Warmth (chrome → fire)', min: 0, max: 1, step: 0.05, val: 0.65 },
  { key: 'speed', label: 'Speed', min: 0, max: 1.5, step: 0.05, val: 0.3 },
  { key: 'liquid', label: 'Liquify', min: 0, max: 1.5, step: 0.05, val: 0.6 },
  { key: 'dispersion', label: 'Dispersion', min: 0, max: 0.15, step: 0.005, val: 0.04 },
  { key: 'scale', label: 'Pattern scale', min: 0.5, max: 6, step: 0.1, val: 2.2 },
  { key: 'edge', label: 'Edge softness', min: 0.02, max: 0.5, step: 0.01, val: 0.12 },
];
---

<Layout title="Liquid-Metal Logo — Preview">
  <main class="pg" data-bg="dark">
    <header class="pg__head">
      <h1>Liquid-Metal Logo</h1>
      <p>The Digcy-style shader on the logomark. Slide <strong>Warmth</strong> from chrome to fiery orange/gold. Tune the rest and tell me where to lock it in before we wire it to the nav.</p>
    </header>

    <div class="pg__stage-wrap">
      <canvas class="pg__canvas" width="600" height="600" aria-label="Liquid-metal logo preview"></canvas>
      <p class="pg__err" data-err hidden></p>
    </div>

    <div class="pg__controls">
      {
        CONTROLS.map((c) => (
          <label class="pg__ctl">
            <span class="pg__ctl-label">{c.label}</span>
            <input type="range" min={c.min} max={c.max} step={c.step} value={c.val} data-param={c.key} />
            <span class="pg__ctl-val" data-val={c.key}>{c.val}</span>
          </label>
        ))
      }
      <label class="pg__toggle"><input type="checkbox" data-darkbg checked /> Dark backdrop</label>
    </div>
  </main>
</Layout>

<script>
  import { LiquidLogo, type LiquidParams } from '../scripts/liquid-logo';

  const canvas = document.querySelector<HTMLCanvasElement>('.pg__canvas');
  const main = document.querySelector<HTMLElement>('.pg');
  const err = document.querySelector<HTMLElement>('[data-err]');

  if (canvas && main) {
    try {
      const lab = new LiquidLogo(canvas);
      lab.load('/favicon.svg').catch(() => showError('Could not load the logo image.'));

      document.querySelectorAll<HTMLInputElement>('[data-param]').forEach((input) => {
        const key = input.dataset.param as keyof LiquidParams;
        const out = document.querySelector<HTMLElement>(`[data-val="${key}"]`);
        input.addEventListener('input', () => {
          const v = parseFloat(input.value);
          lab.setParam(key, v);
          if (out) out.textContent = v.toFixed(key === 'dispersion' ? 3 : 2);
        });
      });

      const darkBg = document.querySelector<HTMLInputElement>('[data-darkbg]');
      darkBg?.addEventListener('change', () => {
        main.dataset.bg = darkBg.checked ? 'dark' : 'light';
      });
    } catch {
      showError('WebGL2 is not available in this browser.');
    }
  }

  function showError(msg: string) {
    if (err) {
      err.textContent = msg;
      err.hidden = false;
    }
  }
</script>

<style>
  .pg {
    min-height: 100vh;
    display: grid;
    align-content: start;
    gap: 2.5rem;
    padding: clamp(2rem, 6vh, 5rem) 1.5rem 4rem;
    max-width: 56rem;
    margin-inline: auto;
  }

  .pg__head h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
  }

  .pg__head p {
    color: var(--ink-2);
    max-width: 52ch;
    margin-top: 0.75rem;
  }

  .pg__stage-wrap {
    position: relative;
    display: grid;
    place-items: center;
    padding: 2rem;
    border-radius: var(--radius-card);
    border: 1px solid var(--line);
    transition: background 0.3s ease;
  }

  .pg[data-bg='light'] .pg__stage-wrap {
    background: #f0f1f3;
  }

  .pg[data-bg='dark'] .pg__stage-wrap {
    background: #0c0d11;
    border-color: #262a30;
  }

  .pg__canvas {
    width: min(70vw, 360px);
    height: min(70vw, 360px);
    display: block;
  }

  .pg__err {
    color: #c0392b;
    font-size: var(--text-small);
  }

  .pg__controls {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1rem 1.5rem;
    align-items: center;
  }

  .pg__ctl {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 0.25rem 0.5rem;
    font-size: var(--text-small);
    font-weight: 600;
  }

  .pg__ctl-label {
    grid-column: 1 / -1;
    color: var(--ink-2);
  }

  .pg__ctl input {
    width: 100%;
  }

  .pg__ctl-val {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink);
    min-width: 3ch;
    text-align: right;
  }

  .pg__toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--text-small);
    font-weight: 600;
  }
</style>
