---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import ContactCTA from '../../components/sections/ContactCTA.astro';
import '../../styles/case-study.css'; // reuse the .prose article typography

const IS_STAGING = import.meta.env.PUBLIC_STAGING === 'true';

// Static mode: export getStaticPaths for pre-rendering
export async function getStaticPaths() {
  if (process.env.PUBLIC_STAGING === 'true') return [];
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}
export const prerender = process.env.PUBLIC_STAGING !== 'true';

// SSR mode: resolve via Astro.params; static mode: resolve via Astro.props
let post;
if (IS_STAGING) {
  const { slug } = Astro.params;
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  post = posts.find((p) => p.id === slug);
  if (!post) return Astro.redirect('/404');
} else {
  post = Astro.props.post;
}

const { Content } = await render(post);
const d = post.data;
const date = d.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Compute previous and next posts for navigation
const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const currentIdx = allPosts.findIndex((p) => p.id === post.id);
const prevPost = currentIdx > 0 ? allPosts[currentIdx - 1] : undefined;
const nextPost = currentIdx < allPosts.length - 1 ? allPosts[currentIdx + 1] : undefined;

const AUTHOR = 'Opeyemi';
const avatarModules = import.meta.glob(
  '/public/avatar.{png,jpg,jpeg,webp,avif}',
  { eager: true, query: '?url' }
);
const avatarFile = Object.keys(avatarModules)[0]?.replace('/public/', '');
const AVATAR = avatarFile ? `/${avatarFile}` : null;
---

<Layout title={`${d.title} — Opeyemi Ajagbe`} description={d.description}>
  <Nav />
  <main>
    <article class="post">
      <header class="post__header">
        <a class="post__back" href="/blog">← All stories</a>
        <p class="eyebrow">{date}</p>
        <h1 class="post__title">{d.title}</h1>
        <p class="post__lead">{d.description}</p>
        <div class="post__byline">
          {AVATAR && <img class="post__avatar" src={AVATAR} alt="" width="40" height="40" loading="lazy" />}
          <span class="post__author">{AUTHOR}</span>
        </div>
      </header>

      {
        d.cover && (
          <div class="post__cover">
            <img src={d.cover} alt="" />
          </div>
        )
      }

      <div class="prose">
        <Content />
      </div>

      {(prevPost || nextPost) && (
        <nav class="post__pager" aria-label="More stories">
          {prevPost ? (
            <a class="post__pager-link post__pager-link--prev" href={`/blog/${prevPost.id}`}>
              <span class="post__pager-label">← Previous</span>
              <span class="post__pager-title">{prevPost.data.title}</span>
            </a>
          ) : (
            <span />
          )}
          {nextPost ? (
            <a class="post__pager-link post__pager-link--next" href={`/blog/${nextPost.id}`}>
              <span class="post__pager-label">Next →</span>
              <span class="post__pager-title">{nextPost.data.title}</span>
            </a>
          ) : (
            <span />
          )}
        </nav>
      )}
    </article>

    <ContactCTA />
  </main>
</Layout>

<style>
  .post {
    padding-top: clamp(7rem, 16vh, 10rem);
    padding-bottom: clamp(4rem, 10vh, 7rem);
  }

  .post__header {
    width: min(100% - 3rem, 46rem);
    margin-inline: auto;
    display: grid;
    justify-items: start;
    gap: 1rem;
  }

  .post__back {
    color: var(--ink-2);
    font-size: var(--text-small);
    font-weight: 600;
    transition: color 0.2s;
  }
  .post__back:hover {
    color: var(--ink);
  }

  .post__title {
    font-size: clamp(2.25rem, 6vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .post__lead {
    color: var(--ink-2);
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    line-height: 1.5;
    max-width: 44ch;
  }

  .post__byline {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 0.5rem;
  }
  .post__avatar {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    object-fit: cover;
    display: block;
  }
  .post__author {
    font-weight: 600;
    font-size: var(--text-small);
  }

  .post__cover {
    width: min(100% - 3rem, var(--container));
    margin: clamp(2.5rem, 6vw, 5rem) auto 0;
  }
  .post__cover img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius-card);
  }

  .prose {
    margin-top: clamp(2.5rem, 6vw, 5rem);
  }

  .post__pager {
    width: min(100% - 3rem, 46rem);
    margin: clamp(3rem, 8vw, 6rem) auto 0;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
  }
  .post__pager-link {
    display: grid;
    gap: 0.3rem;
    text-decoration: none;
    color: inherit;
  }
  .post__pager-link--next {
    text-align: right;
  }
  .post__pager-label {
    font-size: var(--text-eyebrow);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-2);
  }
  .post__pager-title {
    font-size: clamp(1.15rem, 2vw, 1.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    transition: color 0.2s;
  }
  .post__pager-link:hover .post__pager-title {
    color: var(--accent-text);
  }
  @media (max-width: 520px) {
    .post__pager {
      flex-direction: column;
    }
    .post__pager-link--next {
      text-align: left;
    }
  }
</style>
