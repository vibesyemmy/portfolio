---
import { getCollection, render } from 'astro:content';
import ProjectLayout from '../../layouts/ProjectLayout.astro';
import MediaFull from '../../components/case-study/MediaFull.astro';
import MediaGrid from '../../components/case-study/MediaGrid.astro';
import Gallery from '../../components/case-study/Gallery.astro';
import Quote from '../../components/case-study/Quote.astro';
import Metrics from '../../components/case-study/Metrics.astro';
import ColorPalette from '../../components/case-study/ColorPalette.astro';
import TypeSpecimen from '../../components/case-study/TypeSpecimen.astro';
import LogoGrid from '../../components/case-study/LogoGrid.astro';
import StoreBadges from '../../components/case-study/StoreBadges.astro';
import ProtoEmbed from '../../components/case-study/ProtoEmbed.astro';
import ContentGate from '../../components/case-study/ContentGate.astro';

const IS_STAGING = import.meta.env.PUBLIC_STAGING === 'true';

// Static mode: export getStaticPaths for pre-rendering
export async function getStaticPaths() {
  if (process.env.PUBLIC_STAGING === 'true') return [];
  const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
    (a, b) => a.data.order - b.data.order
  );
  return projects.map((project, i) => ({
    params: { slug: project.id },
    props: { project, prev: projects[i - 1], next: projects[i + 1] },
  }));
}
export const prerender = process.env.PUBLIC_STAGING !== 'true';

// SSR mode: resolve via Astro.params; static mode: resolve via Astro.props
let project, prev, next;
if (IS_STAGING) {
  const { slug } = Astro.params;
  const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
    (a, b) => a.data.order - b.data.order
  );
  const idx = projects.findIndex((p) => p.id === slug);
  if (idx === -1) return Astro.redirect('/404');
  project = projects[idx];
  prev = projects[idx - 1] ?? undefined;
  next = projects[idx + 1] ?? undefined;
} else {
  project = Astro.props.project;
  prev = Astro.props.prev;
  next = Astro.props.next;
}

const { Content } = await render(project);

// the block kit, available in MDX bodies without per-file imports
const components = {
  MediaFull,
  MediaGrid,
  Gallery,
  Quote,
  Metrics,
  ColorPalette,
  TypeSpecimen,
  LogoGrid,
  StoreBadges,
  ProtoEmbed,
};

// Case studies still in progress sit behind a client-side password gate
// (ContentGate). One shared hash: the same password unlocks every gated study.
const GATED_PROJECTS = new Set(['lotti', 'gangan']);
const GATE_HASH = 'e0050ea98e743cfc0780afeb7deed1ee8c3428ef875ec84b790be0e8fdd7d4e3';
---

{
  GATED_PROJECTS.has(project.id) ? (
    <ContentGate projectId={project.id} passwordHash={GATE_HASH}>
      <ProjectLayout project={project} prev={prev} next={next}>
        <Content components={components} />
      </ProjectLayout>
    </ContentGate>
  ) : (
    <ProjectLayout project={project} prev={prev} next={next}>
      <Content components={components} />
    </ProjectLayout>
  )
}
