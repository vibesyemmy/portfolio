---
import { getCollection, render } from 'astro:content';
import ProjectLayout from '../../layouts/ProjectLayout.astro';
import MediaFull from '../../components/case-study/MediaFull.astro';
import MediaGrid from '../../components/case-study/MediaGrid.astro';
import Gallery from '../../components/case-study/Gallery.astro';
import Quote from '../../components/case-study/Quote.astro';
import Metrics from '../../components/case-study/Metrics.astro';
import ColorPalette from '../../components/case-study/ColorPalette.astro';
import TypeSpecimen from '../../components/case-study/TypeSpecimen.astro';
import LogoGrid from '../../components/case-study/LogoGrid.astro';
import StoreBadges from '../../components/case-study/StoreBadges.astro';
import ProtoEmbed from '../../components/case-study/ProtoEmbed.astro';

const { slug } = Astro.params;

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
const idx = projects.findIndex((p) => p.id === slug);
if (idx === -1) return Astro.redirect('/404');

const project = projects[idx];
const prev = projects[idx - 1] ?? undefined;
const next = projects[idx + 1] ?? undefined;
const { Content } = await render(project);

// the block kit, available in MDX bodies without per-file imports
const components = {
  MediaFull,
  MediaGrid,
  Gallery,
  Quote,
  Metrics,
  ColorPalette,
  TypeSpecimen,
  LogoGrid,
  StoreBadges,
  ProtoEmbed,
};
---

<ProjectLayout project={project} prev={prev} next={next}>
  <Content components={components} />
</ProjectLayout>
