---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Heatmap Logo — Preview">
  <main class="pg" data-bg="dark">
    <header class="pg__head">
      <h1>Heatmap Logo</h1>
      <p>Your Paper Shaders "Heatmap" config, imported and running on our logomark. Toggle the backdrop to judge it on light vs dark.</p>
    </header>

    <div class="pg__stage-wrap">
      <div class="pg__stage" data-heatmap></div>
      <p class="pg__err" data-err hidden></p>
    </div>

    <label class="pg__toggle"><input type="checkbox" data-darkbg checked /> Dark backdrop</label>
  </main>
</Layout>

<script>
  import { mountHeatmapLogo } from '../scripts/heatmap-logo';

  const stage = document.querySelector<HTMLElement>('[data-heatmap]');
  const main = document.querySelector<HTMLElement>('.pg');
  const err = document.querySelector<HTMLElement>('[data-err]');

  if (stage && main) {
    mountHeatmapLogo(stage, { image: '/logo-opeyemi.svg' }).then((mount) => {
      if (!mount && err) {
        err.textContent = 'Could not load the shader / logo.';
        err.hidden = false;
      }
    });

    const darkBg = document.querySelector<HTMLInputElement>('[data-darkbg]');
    darkBg?.addEventListener('change', () => {
      main.dataset.bg = darkBg.checked ? 'dark' : 'light';
    });
  }
</script>

<style>
  .pg {
    min-height: 100vh;
    display: grid;
    align-content: start;
    gap: 2.5rem;
    padding: clamp(2rem, 6vh, 5rem) 1.5rem 4rem;
    max-width: 56rem;
    margin-inline: auto;
  }

  .pg__head h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
  }

  .pg__head p {
    color: var(--ink-2);
    max-width: 52ch;
    margin-top: 0.75rem;
  }

  .pg__stage-wrap {
    position: relative;
    display: grid;
    place-items: center;
    padding: 2rem;
    border-radius: var(--radius-card);
    border: 1px solid var(--line);
    transition: background 0.3s ease;
  }

  .pg[data-bg='light'] .pg__stage-wrap {
    background: #f0f1f3;
  }

  .pg[data-bg='dark'] .pg__stage-wrap {
    background: #0c0d11;
    border-color: #262a30;
  }

  /* ShaderMount injects a canvas sized to this box; match the wordmark aspect */
  .pg__stage {
    width: min(90vw, 760px);
    aspect-ratio: 183 / 32;
  }

  .pg__err {
    color: #c0392b;
    font-size: var(--text-small);
  }

  .pg__toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--text-small);
    font-weight: 600;
  }
</style>
