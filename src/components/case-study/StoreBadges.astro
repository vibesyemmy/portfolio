---
// A 3-up grid of store badges. Click-to-zoom is handled globally by the
// case-study Lightbox (it binds every .cs-grid image), so this is just a
// semantically-named MediaGrid preset.
import MediaGrid from './MediaGrid.astro';

interface Props {
  items: { src: string; alt: string; caption: string }[];
}
const { items } = Astro.props;
---

<MediaGrid cols={3} width="content" items={items} />
