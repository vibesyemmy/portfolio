---
// Logo lockups / variations. `bg` sets a per-tile background (for light/dark lockups).
interface Item {
  src: string;
  label?: string;
  bg?: string;
}
interface Props {
  items?: Item[];
  width?: 'content' | 'wide' | 'full';
}
const { items = [], width = 'wide' } = Astro.props;
---

<div class="cs-logos" data-width={width}>
  {
    items.map((it) => (
      <figure class="cs-logo" style={it.bg ? `background:${it.bg}` : undefined}>
        <img src={it.src} alt={it.label || ''} loading="lazy" />
        {it.label && <figcaption>{it.label}</figcaption>}
      </figure>
    ))
  }
</div>

<style>
  .cs-logos {
    margin: clamp(2rem, 5vw, 4rem) 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: 1rem;
  }
  .cs-logo {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    aspect-ratio: 4 / 3;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    padding: 1.75rem;
  }
  .cs-logo img {
    max-width: 72%;
    max-height: 48%;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .cs-logo figcaption {
    color: var(--ink-2);
    font-size: var(--text-small);
  }
</style>
