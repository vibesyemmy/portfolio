---
// A 2- or 3-up grid of images or autoplaying videos.
interface Item {
  src: string;
  alt?: string;
  caption?: string;
  poster?: string; // poster frame for video items
}
interface Props {
  items?: Item[];
  cols?: 2 | 3;
  width?: 'content' | 'wide' | 'full';
}
const { items = [], cols = 2, width = 'wide' } = Astro.props;
const isVideo = (src: string) => /\.(mp4|webm|mov)$/i.test(src);
---

<div class="cs-grid" data-width={width} style={`--cols:${cols}`}>
  {
    items.map((it) => (
      <figure>
        {isVideo(it.src) ? (
          <video
            src={it.src}
            poster={it.poster}
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
          />
        ) : (
          <img src={it.src} alt={it.alt || ''} loading="lazy" />
        )}
        {it.caption && <figcaption>{it.caption}</figcaption>}
      </figure>
    ))
  }
</div>

<style>
  .cs-grid {
    margin: clamp(2rem, 5vw, 4rem) 0;
    display: grid;
    grid-template-columns: repeat(var(--cols, 2), 1fr);
    gap: clamp(0.75rem, 2vw, 1.5rem);
  }
  .cs-grid figure {
    margin: 0;
  }
  .cs-grid :where(img, video) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-card);
  }
  .cs-grid figcaption {
    margin-top: 0.5rem;
    color: var(--ink-2);
    font-size: var(--text-small);
  }
  @media (max-width: 640px) {
    .cs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
