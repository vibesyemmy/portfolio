---
// Embedded interactive prototype (ProtoPie, Figma, etc.) as a responsive,
// aspect-locked iframe that sits in the case-study reading grid via data-width.
interface Props {
  src: string;
  title?: string;
  width?: 'content' | 'wide' | 'full' | 'container';
  ratio?: string; // CSS aspect-ratio, e.g. "16 / 9"
  caption?: string;
}
const {
  src,
  title = 'Interactive prototype',
  width = 'container',
  ratio = '16 / 9',
  caption,
} = Astro.props;
---

<figure class="cs-proto" data-width={width}>
  <div class="cs-proto__frame" style={`aspect-ratio:${ratio}`}>
    <iframe
      src={src}
      title={title}
      loading="lazy"
      allow="fullscreen; accelerometer; gyroscope; clipboard-write"
      allowfullscreen></iframe>
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<script>
  // Embedded players (ProtoPie etc.) only receive their keyboard shortcuts —
  // R to restart, Esc to go back — while the iframe itself holds focus. In an
  // embed the parent page keeps focus, so keystrokes never reach the prototype.
  // Hand focus to the frame as soon as the pointer is over it: this gives the
  // same R/Esc behaviour as the standalone player, with no click required.
  for (const frame of document.querySelectorAll<HTMLIFrameElement>('.cs-proto iframe')) {
    const focusFrame = () => {
      try {
        frame.contentWindow?.focus();
      } catch {
        /* cross-origin focus() is allowed; ignore the rare throw */
      }
    };
    frame.addEventListener('pointerenter', focusFrame);
    frame.addEventListener('pointerdown', focusFrame);
  }
</script>

<style>
  .cs-proto {
    margin: clamp(2rem, 5vw, 4rem) 0;
  }
  .cs-proto__frame {
    position: relative;
    width: 100%;
    border-radius: var(--radius-card);
    overflow: hidden;
    background: #f5f5f5;
    border: 1px solid var(--line);
  }
  .cs-proto__frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
  .cs-proto figcaption {
    margin-top: 0.75rem;
    color: var(--ink-2);
    font-size: var(--text-small);
    text-align: center;
  }
</style>
