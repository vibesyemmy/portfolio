---
// Horizontal, snap-scrolling image gallery.
interface Item {
  src: string;
  alt?: string;
}
interface Props {
  items?: Item[];
  width?: 'wide' | 'full';
}
const { items = [], width = 'full' } = Astro.props;
---

<div class="cs-gallery" data-width={width}>
  <div class="cs-gallery__track">
    {items.map((it) => <img src={it.src} alt={it.alt || ''} loading="lazy" />)}
  </div>
</div>

<style>
  .cs-gallery {
    margin: clamp(2rem, 5vw, 4rem) 0;
  }
  .cs-gallery__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: min(82%, 34rem);
    gap: 1rem;
    height: clamp(16rem, 42vh, 30rem);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-inline: clamp(1.5rem, 5vw, 4rem);
    scrollbar-width: none;
  }
  .cs-gallery__track::-webkit-scrollbar {
    display: none;
  }
  .cs-gallery__track img {
    scroll-snap-align: center;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-card);
  }
</style>
