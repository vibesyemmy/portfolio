---
import { getCollection, render } from 'astro:content';

const testimonials = (await getCollection('testimonials', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);

const rendered = await Promise.all(
  testimonials.map(async (t) => ({ ...t, Content: (await render(t)).Content }))
);
---

<section class="dark-section section" aria-label="Testimonials">
  <div class="container">
    <h2 class="h2" data-split>Testimonials</h2>
    <div
      class="row"
      data-stagger
      data-fade-scroll
      tabindex="0"
      role="group"
      aria-label="Client testimonials"
    >
      {
        rendered.map((t) => (
          <figure class="quote">
            <blockquote>
              <t.Content />
            </blockquote>
            <figcaption>
              — {t.data.author}, {t.data.role}
              {t.data.company ? ` · ${t.data.company}` : ''}
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>

<script>
  // Scroll-aware edge fades: left fade appears only after scrolling, right fade
  // shrinks to nothing at the end.
  document.querySelectorAll<HTMLElement>('[data-fade-scroll]').forEach((row) => {
    const FADE = 64; // px — matches the --fade-right default (4rem)
    const update = () => {
      const max = row.scrollWidth - row.clientWidth;
      row.style.setProperty('--fade-left', `${Math.min(row.scrollLeft, FADE)}px`);
      row.style.setProperty('--fade-right', `${Math.min(Math.max(max - row.scrollLeft, 0), FADE)}px`);
    };
    row.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
  });
</script>

<style>
  /* oversized faded outline title, dropped behind the cards which overlap it */
  .h2 {
    position: relative;
    z-index: 0;
    font-size: clamp(2.75rem, 13vw, 12rem);
    line-height: 0.9;
    color: transparent;
    -webkit-text-stroke: 1.5px rgb(255 255 255 / 22%);
    /* let the card row overlap the lower part of the title (showing more of it) */
    margin-bottom: -0.3em;
    white-space: nowrap;
    pointer-events: none;
  }

  .row {
    position: relative;
    z-index: 1;
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(20rem, 27rem);
    gap: 1.25rem;
    margin-top: 0;
    overflow-x: auto;
    padding-bottom: 1rem;
    /* edge fade, scroll-aware via JS: left starts solid (card at the start) and
       grows once scrolled; right fade disappears at the end. No-JS keeps the
       rest-state defaults below (left solid, right faded). */
    --fade-left: 0px;
    --fade-right: 4rem;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0,
      #000 var(--fade-left),
      #000 calc(100% - var(--fade-right)),
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0,
      #000 var(--fade-left),
      #000 calc(100% - var(--fade-right)),
      transparent 100%
    );
    /* hide the scrollbar (still scrollable via drag / trackpad / keyboard) */
    scrollbar-width: none;
  }

  .row::-webkit-scrollbar {
    display: none;
  }

  .quote {
    background: var(--dark-surface);
    border-radius: var(--radius-card);
    padding: 1.5rem;
  }

  .quote blockquote {
    font-size: var(--text-body);
  }

  .quote figcaption {
    margin-top: 1rem;
    color: var(--dark-ink-2);
    font-size: var(--text-small);
  }
</style>
