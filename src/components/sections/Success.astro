---
import { getCollection, render } from 'astro:content';

const testimonials = (await getCollection('testimonials', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);

const rendered = await Promise.all(
  testimonials.map(async (t) => ({ ...t, Content: (await render(t)).Content }))
);

const companies = ['Kobo360', 'Hydrogen Pay', 'ggCircuit'];
---

<section class="dark-section section" aria-label="Testimonials">
  <div class="container">
    <h2 class="h2" data-split>Testimonials</h2>
    <div class="row" data-stagger tabindex="0" role="group" aria-label="Client testimonials">
      {
        rendered.map((t) => (
          <figure class="quote">
            <blockquote>
              <t.Content />
            </blockquote>
            <figcaption>
              — {t.data.author}, {t.data.role}
              {t.data.company ? ` · ${t.data.company}` : ''}
            </figcaption>
          </figure>
        ))
      }
    </div>
    <ul class="logos" data-reveal>
      {companies.map((c) => <li>{c}</li>)}
    </ul>
  </div>
</section>

<style>
  /* oversized faded outline title, dropped behind the cards which overlap it */
  .h2 {
    position: relative;
    z-index: 0;
    font-size: clamp(2.75rem, 13vw, 12rem);
    line-height: 0.9;
    color: transparent;
    -webkit-text-stroke: 1.5px rgb(255 255 255 / 22%);
    /* let the card row overlap the lower half of the title */
    margin-bottom: -0.45em;
    white-space: nowrap;
    pointer-events: none;
  }

  .row {
    position: relative;
    z-index: 1;
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(18rem, 24rem);
    gap: 1.25rem;
    margin-top: 0;
    overflow-x: auto;
    padding-bottom: 1rem;
    scrollbar-width: thin;
  }

  .quote {
    background: var(--dark-surface);
    border-radius: var(--radius-card);
    padding: 1.5rem;
  }

  .quote blockquote {
    font-size: var(--text-body);
  }

  .quote figcaption {
    margin-top: 1rem;
    color: var(--dark-ink-2);
    font-size: var(--text-small);
  }

  .logos {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    margin-top: 3rem;
    list-style: none;
    padding: 0;
    font-weight: 700;
    color: var(--dark-ink-2);
  }

  .logos li {
    transition: color 0.25s;
  }

  .logos li:hover {
    color: var(--dark-ink);
  }
</style>
