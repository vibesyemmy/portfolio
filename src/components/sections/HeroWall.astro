---
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
const names = projects.map((p) => p.data.title);

// Placeholder tile styles (light-theme friendly, brand-tinted). To use a real
// screenshot later, give a tile an <img> in place of the gradient background.
const gradients = [
  'linear-gradient(150deg, #fde2b8, #fb9826)',
  'linear-gradient(150deg, #cfeaff, #0099ff)',
  'linear-gradient(150deg, #ffffff, #d9d9d9)',
  'linear-gradient(150deg, #ffe0c2, #ff7a45)',
  'linear-gradient(150deg, #e7ecff, #6f8cff)',
  'linear-gradient(150deg, #1d1d1d, #3c3c3c)',
];
const ratios = ['3 / 4', '4 / 3', '1 / 1', '9 / 16', '4 / 5'];

const COLUMNS = 5;
const TILES_PER_COL = 4;

const columns = Array.from({ length: COLUMNS }, (_, c) =>
  Array.from({ length: TILES_PER_COL }, (_, r) => {
    const i = c * TILES_PER_COL + r;
    return {
      label: names.length ? names[i % names.length] : `Project ${i + 1}`,
      gradient: gradients[i % gradients.length],
      ratio: ratios[(i + c) % ratios.length],
      dark: i % gradients.length === 5,
    };
  })
);

// Per-column motion: alternating direction, varied speed.
const colMeta = Array.from({ length: COLUMNS }, (_, c) => ({
  dir: c % 2 === 0 ? 'up' : 'down',
  dist: 80 + (c % 3) * 50, // 80, 130, 180, 80, 130 — px of scroll-parallax travel
}));
---

<section class="hero-wall" aria-label="Intro">
  <div class="hero-wall__content container">
    <p class="eyebrow" data-reveal>Senior Product Designer — 9+ Years</p>
    <h1 class="hero-wall__title" data-split>
      Designing digital experiences that feel intuitive &amp; alive
    </h1>
    <p class="hero-wall__sub" data-reveal>
      Fintech · Logistics · Edu-tech · E-sport — design &amp; build
    </p>
    <a class="pill" href="#work" data-reveal data-magnetic>See projects ↓</a>
  </div>

  <div class="wall" aria-hidden="true">
    {
      columns.map((col, c) => (
        <div class="wall__col">
          <div
            class="wall__track"
            data-wall-track
            data-dir={colMeta[c].dir}
            data-dist={colMeta[c].dist}
          >
            {[...col, ...col].map((tile) => (
              <div
                class="tile"
                data-dark={tile.dark}
                style={`aspect-ratio:${tile.ratio};background:${tile.gradient}`}
              >
                <span class="tile__label">{tile.label}</span>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Scroll-driven parallax: adjacent columns drift in opposite directions as
  // the hero scrolls past. Nothing moves at rest. Gated for reduced-motion.
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const section = document.querySelector<HTMLElement>('.hero-wall');
    if (section) {
      document.querySelectorAll<HTMLElement>('[data-wall-track]').forEach((track) => {
        const down = track.dataset.dir === 'down';
        const dist = parseFloat(track.dataset.dist || '120');
        gsap.fromTo(
          track,
          { y: 0 },
          {
            y: down ? dist : -dist,
            ease: 'none',
            scrollTrigger: {
              trigger: section,
              start: 'top top',
              end: 'bottom top',
              scrub: 1,
            },
          }
        );
      });
    }
  }
</script>

<style>
  .hero-wall {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    isolation: isolate;
  }

  .hero-wall__content {
    position: relative;
    z-index: 2;
    flex: 0 0 auto;
    display: grid;
    justify-items: center;
    text-align: center;
    gap: 1.5rem;
    padding-block: clamp(7rem, 16vh, 11rem) clamp(2.5rem, 5vh, 4rem);
  }

  .hero-wall__title {
    font-size: var(--text-display);
    max-width: 18ch;
  }

  .hero-wall__sub {
    color: var(--ink-2);
    max-width: 42ch;
  }

  .wall {
    position: relative;
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    padding-inline: 1.25rem;
    overflow: hidden;
    pointer-events: none;
    /* cards emerge from the page background at the top edge */
    -webkit-mask-image: linear-gradient(to bottom, transparent, #000 14%);
    mask-image: linear-gradient(to bottom, transparent, #000 14%);
  }

  .wall__col {
    flex: 0 0 clamp(170px, 16vw, 270px);
  }

  .wall__col:nth-child(even) {
    margin-top: -6%;
  }

  .wall__track {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    will-change: transform;
  }

  .tile {
    width: 100%;
    border-radius: 14px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 6px 20px rgb(0 0 0 / 7%);
  }

  .tile__label {
    position: absolute;
    left: 12px;
    bottom: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--ink);
    background: rgb(255 255 255 / 72%);
    padding: 3px 9px;
    border-radius: var(--radius-pill);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .tile[data-dark='true'] .tile__label {
    color: #fff;
    background: rgb(0 0 0 / 38%);
  }

  @media (max-width: 900px) {
    .wall__col:nth-child(n + 5) {
      display: none;
    }
  }

  @media (max-width: 560px) {
    .wall__col:nth-child(n + 3) {
      display: none;
    }
  }
</style>
