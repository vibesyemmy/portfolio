---
import fs from 'node:fs';
import { getCollection } from 'astro:content';

// Read intrinsic image ratio (height / width) from a public-path image header so
// columns can be balanced by height. Handles PNG + JPEG; other formats fall back.
function imageRatio(publicPath: string): number {
  try {
    const buf = fs.readFileSync(`public${decodeURIComponent(publicPath)}`);
    if (buf.length >= 24 && buf.toString('ascii', 12, 16) === 'IHDR') {
      const w = buf.readUInt32BE(16);
      const h = buf.readUInt32BE(20);
      if (w) return h / w;
    }
    if (buf[0] === 0xff && buf[1] === 0xd8) {
      let o = 2;
      while (o < buf.length - 8) {
        if (buf[o] !== 0xff) {
          o++;
          continue;
        }
        const m = buf[o + 1];
        if (m >= 0xc0 && m <= 0xcf && m !== 0xc4 && m !== 0xc8 && m !== 0xcc) {
          const h = buf.readUInt16BE(o + 5);
          const w = buf.readUInt16BE(o + 7);
          if (w) return h / w;
        }
        o += 2 + buf.readUInt16BE(o + 2);
      }
    }
  } catch {
    /* fall through to default */
  }
  return 0.72;
}

// Real case studies (each has a /work/[slug] page). Every project gets one
// clear, clickable card; the remaining demo cards keep the wall full but are
// shown "locked" (blurred + Coming soon on hover) until a real project backs them.
const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);

// Demo placeholder imagery — replace with real, optimised covers before launch.
const files: string[] = fs
  .readdirSync('public/demo-img')
  .filter((f: string) => /\.(png|jpe?g|webp|avif)$/i.test(f))
  .sort();

const COLUMNS = 4;

interface Tile {
  src: string;
  locked: boolean;
  href?: string;
  title?: string;
}

// Available case studies lead the wall so they take the prominent top row of
// every column; the remaining demo cards fill in below as "locked" placeholders
// to keep the wall full. The bin-packer below fills each column top-down in this
// order, so real-first means real-on-top.
const realTiles: Tile[] = projects.map((p, i) => ({
  // real cards show their own cover; fall back to a placeholder if unset
  src: p.data.cover ?? `/demo-img/${encodeURIComponent(files[i % files.length])}`,
  locked: false,
  href: `/work/${p.id}`,
  title: p.data.title,
}));
const lockedCount = Math.max(0, files.length - realTiles.length);
const lockedTiles: Tile[] = files.slice(0, lockedCount).map((f) => ({
  src: `/demo-img/${encodeURIComponent(f)}`,
  locked: true,
}));
const cards: Tile[] = [...realTiles, ...lockedTiles];

// Height-balanced bin-packing: each card goes to the currently shortest column.
const columns: Tile[][] = Array.from({ length: COLUMNS }, () => []);
const colHeights: number[] = new Array(COLUMNS).fill(0);
cards.forEach((card) => {
  let min = 0;
  for (let c = 1; c < COLUMNS; c++) if (colHeights[c] < colHeights[min]) min = c;
  columns[min].push(card);
  colHeights[min] += imageRatio(card.src) + 0.05; // ratio + gap allowance
});

const colMeta = Array.from({ length: COLUMNS }, (_, c) => ({
  dir: c % 2 === 0 ? 'up' : 'down',
  dist: 50 + (c % 3) * 35, // px of scroll-parallax travel (kept under the overfill)
}));

// Mobile shows just the real, browsable projects (one card each).
const realCards = cards.filter((c) => !c.locked);
const MOBILE_VISIBLE = 6;
---

<section class="hero-wall" aria-label="Intro">
  <div class="hero-wall__content">
    <div class="container hero-wall__inner">
      <div class="hero-wall__avatar" data-reveal data-magnetic>
        <span class="hero-wall__avatar-ring" aria-hidden="true"></span>
        <img src="/avatar.png" alt="Opeyemi Ajagbe" width="88" height="88" />
      </div>
      <p class="eyebrow" data-reveal>Senior Product Designer — 9+ Years</p>
      <h1 class="hero-wall__title" data-split>
        I design and build the things other designers use.
      </h1>
      <p class="hero-wall__sub" data-reveal>
        Systems thinking, code literacy, and the belief that the right component ships faster than the clever one.
      </p>
      <div class="hero-wall__actions" data-reveal>
        <a class="pill" href="#contact" data-magnetic>Let's talk</a>
        <a class="pill pill--ghost" href="#work" data-magnetic>View Projects</a>
      </div>
    </div>
  </div>

  <div id="work" class="hero-wall__anchor" aria-hidden="true"></div>

  <div class="wall">
    {
      columns.map((col, c) => (
        <div class="wall__col">
          <div
            class="wall__track"
            data-wall-track
            data-dir={colMeta[c].dir}
            data-dist={colMeta[c].dist}
          >
            {col.map((it) =>
              it.locked ? (
                <div class="tile tile--locked" data-locked>
                  <img src={it.src} alt="" loading="lazy" />
                  <span class="tile__lock" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="4" y="11" width="16" height="9" rx="2" />
                      <path d="M8 11V8a4 4 0 0 1 8 0v3" />
                    </svg>
                  </span>
                </div>
              ) : (
                <a class="tile" href={it.href}>
                  <img src={it.src} alt={it.title} loading="lazy" />
                  <span class="tile__title">{it.title}</span>
                </a>
              )
            )}
          </div>
        </div>
      ))
    }
  </div>

  <div class="hero-wall__fade" aria-hidden="true"></div>

  <div class="wall-mobile container">
    <ul class="wall-mobile__list" data-wall-mobile-list data-collapsed>
      {
        realCards.map((it, i) => (
          <li class="wall-mobile__item" data-extra={i >= MOBILE_VISIBLE ? 'true' : 'false'}>
            <a href={it.href}>
              <img src={it.src} alt={it.title} loading="lazy" />
              <span class="wall-mobile__title">{it.title}</span>
            </a>
          </li>
        ))
      }
    </ul>
    {realCards.length > MOBILE_VISIBLE && (
      <button class="wall-mobile__toggle" data-wall-toggle data-magnetic aria-expanded="false">
        Show more
      </button>
    )}
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { attachCursorFollower } from '../../scripts/cursor-follower';

  gsap.registerPlugin(ScrollTrigger);

  // Scroll-driven parallax: adjacent columns drift in opposite directions as
  // the hero scrolls past. Nothing moves at rest. Gated for reduced-motion.
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const section = document.querySelector<HTMLElement>('.hero-wall');
    if (section) {
      document.querySelectorAll<HTMLElement>('[data-wall-track]').forEach((track) => {
        const down = track.dataset.dir === 'down';
        const dist = parseFloat(track.dataset.dist || '120');
        // Tracks are top-aligned, so all overfill sits at the bottom. A column
        // that drifts DOWN has no headroom above its first tile, so moving down
        // would expose a bare band at the column's top clip edge (the "janky
        // line" under the panel). Offset its rest position up by `dist` so it
        // drifts -dist -> 0 (top stays at/above the clip edge the whole way).
        // Up columns keep 0 -> -dist. Both drift `dist` in opposite directions;
        // overfill (>> dist) keeps the bottom covered throughout.
        gsap.fromTo(
          track,
          { y: down ? -dist : 0 },
          {
            y: down ? 0 : -dist,
            ease: 'none',
            scrollTrigger: {
              trigger: section,
              start: 'top top',
              end: 'bottom top',
              scrub: 1,
            },
          }
        );
      });
    }
  }

  // cursor follower over the wall: "View Project" on real cards, "Coming soon"
  // on locked placeholders (fine-pointer devices only)
  const wall = document.querySelector<HTMLElement>('.wall');
  if (wall) {
    attachCursorFollower([wall], (t) =>
      (t as HTMLElement | null)?.closest?.('[data-locked]') ? 'Coming soon' : 'View Project'
    );
  }

  // Mobile single-column wall: show more / show less toggle
  document.querySelectorAll<HTMLButtonElement>('[data-wall-toggle]').forEach((btn) => {
    const list = document.querySelector<HTMLElement>('[data-wall-mobile-list]');
    if (!list) return;
    btn.addEventListener('click', () => {
      const nowCollapsed = list.toggleAttribute('data-collapsed');
      btn.setAttribute('aria-expanded', String(!nowCollapsed));
      btn.textContent = nowCollapsed ? 'Show more' : 'Show less';
    });
  });
</script>

<style>
  .hero-wall {
    position: relative;
    /* sizes to its content (panel + wall); the wall's height is width-based
       below, so a tall viewport can't leave empty space under the cards */
    display: flex;
    flex-direction: column;
    overflow: hidden;
    isolation: isolate;
  }

  /* Full-width opaque panel. Cards that drift up on scroll slide BEHIND this
     (occluded, not clipped) so they always keep their rounded corners. Its
     bottom edge is the even line every column starts at. */
  .hero-wall__content {
    position: relative;
    z-index: 2;
    flex: 0 0 auto;
    background: var(--bg);
    padding-block: clamp(7rem, 16vh, 11rem) clamp(2.5rem, 5vh, 4rem);
  }

  .hero-wall__inner {
    display: grid;
    justify-items: center;
    text-align: center;
    gap: 1.5rem;
  }

  .hero-wall__avatar {
    position: relative;
    display: inline-grid;
    place-items: center;
    width: clamp(76px, 9vw, 100px);
    aspect-ratio: 1;
    /* sit a touch closer to the eyebrow than the default grid gap */
    margin-bottom: -0.5rem;
  }

  /* thin conic-gradient ring that slowly spins; masked to a band so only the
     outer edge shows, the photo sits inside with a small gap */
  .hero-wall__avatar-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: conic-gradient(from 0deg, #ffd24d, #fb9826, #0099ff, #ffd24d);
    animation: avatar-ring-spin 8s linear infinite;
    will-change: transform;
  }

  .hero-wall__avatar img {
    position: relative;
    z-index: 1;
    box-sizing: border-box;
    width: calc(100% - 6px);
    height: calc(100% - 6px);
    /* a bg-coloured border forms the gap; the photo and the disc behind are both
       real border-radius circles, so their edges anti-alias cleanly — no masked
       jaggies. Only the conic colours sweep; the ring's edges stay put. */
    border: 3px solid var(--bg);
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 2px 14px rgb(0 0 0 / 10%);
  }

  @keyframes avatar-ring-spin {
    to {
      transform: rotate(1turn);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-wall__avatar-ring {
      animation: none;
    }
  }

  .hero-wall__title {
    font-size: var(--text-display);
    max-width: 18ch;
  }

  .hero-wall__sub {
    color: var(--ink-2);
    max-width: 42ch;
  }

  .hero-wall__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .wall {
    position: relative;
    z-index: 1;
    /* width-proportional height so a tall viewport never leaves empty space
       under the cards (columns still stretch to one even bottom edge) */
    aspect-ratio: 16 / 10;
    /* min-height:0 lets the aspect-ratio set the height — without it a flex
       item's default min-height:auto lets the tallest column force the wall
       taller, leaving shorter columns with empty bottoms */
    min-height: 0;
    /* match the section container: capped at --container, always a 1.5rem
       gutter each side until the cap so cards never touch the screen edges */
    width: min(100% - 3rem, var(--container));
    margin-inline: auto;
    /* overlap the opaque content panel by 1px so the panel/wall seam can't
       flicker as a hairline under Lenis's sub-pixel scroll positions */
    margin-top: -1px;
    display: flex;
    align-items: stretch;
    gap: 0.5rem;
    overflow: visible;
    /* auto so the tiles receive hover for the "View Project" cursor follower */
    pointer-events: auto;
  }

  .wall__col {
    /* grow equally to fill the wall width so the columns span the full section */
    flex: 1 1 0;
    min-width: 0;
    /* each column crops its own parallax with rounded corners, so cards stay
       rounded as they scroll instead of being chopped flat by the wrapper */
    overflow: hidden;
    border-radius: 14px;
  }

  .wall__track {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    will-change: transform;
  }

  .tile {
    position: relative;
    display: block;
    width: 100%;
    border-radius: 14px;
    overflow: hidden;
    background: var(--surface);
    box-shadow: 0 6px 20px rgb(0 0 0 / 7%);
  }

  .tile img {
    display: block;
    width: 100%;
    height: auto;
    transition:
      scale 0.45s ease,
      filter 0.45s ease;
  }

  /* slight zoom marks the hovered card (the cursor is hidden over the wall) */
  .tile:hover img {
    scale: 1.06;
  }

  /* locked placeholders: blur + lock badge on hover, not clickable */
  .tile--locked {
    cursor: default;
  }
  .tile--locked:hover img {
    scale: 1.1;
    filter: blur(7px) brightness(0.55);
  }
  .tile__lock {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: #fff;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }
  .tile--locked:hover .tile__lock {
    opacity: 1;
  }
  .tile__lock svg {
    width: 2rem;
    height: 2rem;
    filter: drop-shadow(0 2px 8px rgb(0 0 0 / 45%));
  }

  /* project title: fade-to-black band + label at the card bottom, on hover */
  .tile__title {
    position: absolute;
    inset: auto 0 0 0;
    padding: 2.25rem 0.9rem 0.8rem;
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.2;
    background: linear-gradient(
      to top,
      rgb(0 0 0 / 88%),
      rgb(0 0 0 / 55%) 45%,
      transparent
    );
    opacity: 0;
    transform: translateY(0.5rem);
    transition:
      opacity 0.35s ease,
      transform 0.35s ease;
    pointer-events: none;
  }

  .tile:hover .tile__title {
    opacity: 1;
    transform: translateY(0);
  }

  /* cards dissolve into the page background at the bottom */
  .hero-wall__fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: clamp(6rem, 18vh, 12rem);
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(to bottom, transparent, var(--bg));
  }

  /* mobile single-column expandable list (replaces the parallax wall) */
  .wall-mobile {
    display: none;
    /* same gutter as the text container so cards never touch the screen edges */
    width: min(100% - 3rem, var(--container));
    margin-inline: auto;
    padding-bottom: clamp(2rem, 6vh, 4rem);
  }

  .wall-mobile__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }

  .wall-mobile__list[data-collapsed] .wall-mobile__item[data-extra='true'] {
    display: none;
  }

  .wall-mobile__item img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 14px;
    box-shadow: 0 6px 20px rgb(0 0 0 / 7%);
  }

  .wall-mobile__title {
    display: block;
    margin: 0.6rem 0.15rem 0;
    font-size: var(--text-small);
    font-weight: 600;
  }

  .wall-mobile__toggle {
    display: block;
    margin: 1.25rem auto 0;
    padding: 0.65rem 1.6rem;
    border: 1px solid rgb(0 0 0 / 14%);
    border-radius: var(--radius-pill);
    background: var(--surface);
    color: var(--ink);
    font-family: inherit;
    font-size: var(--text-small);
    font-weight: 600;
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .wall-mobile__toggle:hover {
    border-color: rgb(0 0 0 / 28%);
  }

  @media (max-width: 900px) {
    .wall__col:nth-child(n + 4) {
      display: none;
    }
  }

  /* mobile: swap the parallax wall for the single-column expandable list */
  @media (max-width: 600px) {
    .hero-wall {
      min-height: 100svh;
    }

    .wall,
    .hero-wall__fade {
      display: none;
    }

    .wall-mobile {
      display: block;
    }
  }
</style>
