---
import fs from 'node:fs';

const DEMO_DIR = 'public/demo-img';

// Read intrinsic image ratio (height / width) from the file header so columns
// can be balanced by height. Handles PNG + JPEG; other formats fall back.
function imageRatio(file: string): number {
  try {
    const buf = fs.readFileSync(`${DEMO_DIR}/${file}`);
    if (buf.length >= 24 && buf.toString('ascii', 12, 16) === 'IHDR') {
      const w = buf.readUInt32BE(16);
      const h = buf.readUInt32BE(20);
      if (w) return h / w;
    }
    if (buf[0] === 0xff && buf[1] === 0xd8) {
      let o = 2;
      while (o < buf.length - 8) {
        if (buf[o] !== 0xff) {
          o++;
          continue;
        }
        const m = buf[o + 1];
        if (m >= 0xc0 && m <= 0xcf && m !== 0xc4 && m !== 0xc8 && m !== 0xcc) {
          const h = buf.readUInt16BE(o + 5);
          const w = buf.readUInt16BE(o + 7);
          if (w) return h / w;
        }
        o += 2 + buf.readUInt16BE(o + 2);
      }
    }
  } catch {
    /* fall through to default */
  }
  return 0.72;
}

// Demo placeholder images. Drop files into public/demo-img/ and they are picked
// up automatically. Temporary stand-ins served unoptimized from public/ —
// replace with real, owned/licensed, optimized assets (via astro:assets) before
// launch. Each card appears exactly once — no repeats.
const files: string[] = fs
  .readdirSync(DEMO_DIR)
  .filter((f: string) => /\.(png|jpe?g|webp|avif)$/i.test(f))
  .sort();

const imageFiles: string[] = files.map((f: string) => `/demo-img/${encodeURIComponent(f)}`);

const COLUMNS = 4;

// Height-balanced bin-packing: each card goes to the currently shortest column
// so columns end up roughly even — no duplicates needed for balance.
const columns: string[][] = Array.from({ length: COLUMNS }, () => []);
const colHeights: number[] = new Array(COLUMNS).fill(0);
files.forEach((f: string) => {
  let min = 0;
  for (let c = 1; c < COLUMNS; c++) if (colHeights[c] < colHeights[min]) min = c;
  columns[min].push(`/demo-img/${encodeURIComponent(f)}`);
  colHeights[min] += imageRatio(f) + 0.05; // ratio + gap allowance
});

const colMeta = Array.from({ length: COLUMNS }, (_, c) => ({
  dir: c % 2 === 0 ? 'up' : 'down',
  dist: 80 + (c % 3) * 50, // px of scroll-parallax travel
}));

// Mobile collapses to a single-column list: cards shown before the show-more toggle
const MOBILE_VISIBLE = 6;
---

<section class="hero-wall" id="work" aria-label="Intro">
  <div class="hero-wall__content">
    <div class="container hero-wall__inner">
      <p class="eyebrow" data-reveal>Senior Product Designer — 9+ Years</p>
      <h1 class="hero-wall__title" data-split>
        Designing digital experiences that feel intuitive &amp; alive
      </h1>
      <p class="hero-wall__sub" data-reveal>
        Fintech · Logistics · Edu-tech · E-sport — design &amp; build
      </p>
      <a class="pill" href="#contact" data-reveal data-magnetic>Let's talk</a>
    </div>
  </div>

  <div class="wall" aria-hidden="true">
    {
      columns.map((col, c) => (
        <div class="wall__col">
          <div
            class="wall__track"
            data-wall-track
            data-dir={colMeta[c].dir}
            data-dist={colMeta[c].dist}
          >
            {col.map((src) => (
              <div class="tile">
                <img src={src} alt="" loading="lazy" />
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>

  <div class="hero-wall__fade" aria-hidden="true"></div>

  <div class="wall-mobile container">
    <ul class="wall-mobile__list" data-wall-mobile-list data-collapsed>
      {
        imageFiles.map((src, i) => (
          <li class="wall-mobile__item" data-extra={i >= MOBILE_VISIBLE ? 'true' : 'false'}>
            <img src={src} alt="" loading="lazy" />
          </li>
        ))
      }
    </ul>
    {imageFiles.length > MOBILE_VISIBLE && (
      <button class="wall-mobile__toggle" data-wall-toggle data-magnetic aria-expanded="false">
        Show more
      </button>
    )}
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Scroll-driven parallax: adjacent columns drift in opposite directions as
  // the hero scrolls past. Nothing moves at rest. Gated for reduced-motion.
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const section = document.querySelector<HTMLElement>('.hero-wall');
    if (section) {
      document.querySelectorAll<HTMLElement>('[data-wall-track]').forEach((track) => {
        const down = track.dataset.dir === 'down';
        const dist = parseFloat(track.dataset.dist || '120');
        gsap.fromTo(
          track,
          { y: 0 },
          {
            y: down ? dist : -dist,
            ease: 'none',
            scrollTrigger: {
              trigger: section,
              start: 'top top',
              end: 'bottom top',
              scrub: 1,
            },
          }
        );
      });
    }
  }

  // Mobile single-column wall: show more / show less toggle
  document.querySelectorAll<HTMLButtonElement>('[data-wall-toggle]').forEach((btn) => {
    const list = document.querySelector<HTMLElement>('[data-wall-mobile-list]');
    if (!list) return;
    btn.addEventListener('click', () => {
      const nowCollapsed = list.toggleAttribute('data-collapsed');
      btn.setAttribute('aria-expanded', String(!nowCollapsed));
      btn.textContent = nowCollapsed ? 'Show more' : 'Show less';
    });
  });
</script>

<style>
  .hero-wall {
    position: relative;
    /* taller than the viewport so the wall shows more card rows below the fold */
    min-height: 150svh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    isolation: isolate;
  }

  /* Full-width opaque panel. Cards that drift up on scroll slide BEHIND this
     (occluded, not clipped) so they always keep their rounded corners. Its
     bottom edge is the even line every column starts at. */
  .hero-wall__content {
    position: relative;
    z-index: 2;
    flex: 0 0 auto;
    background: var(--bg);
    padding-block: clamp(7rem, 16vh, 11rem) clamp(2.5rem, 5vh, 4rem);
  }

  .hero-wall__inner {
    display: grid;
    justify-items: center;
    text-align: center;
    gap: 1.5rem;
  }

  .hero-wall__title {
    font-size: var(--text-display);
    max-width: 18ch;
  }

  .hero-wall__sub {
    color: var(--ink-2);
    max-width: 42ch;
  }

  .wall {
    position: relative;
    z-index: 1;
    /* flex-basis 0 so the wall fills the viewport remainder at a definite
       height instead of growing to its (tall) content — this lets every
       column stretch to the same height for one even bottom edge */
    flex: 1 1 0;
    min-height: 0;
    /* match the section container: capped at --container, always a 1.5rem
       gutter each side until the cap so cards never touch the screen edges */
    width: min(100% - 3rem, var(--container));
    margin-inline: auto;
    /* overlap the opaque content panel by 1px so the panel/wall seam can't
       flicker as a hairline under Lenis's sub-pixel scroll positions */
    margin-top: -1px;
    display: flex;
    align-items: stretch;
    gap: 0.5rem;
    overflow: visible;
    pointer-events: none;
  }

  .wall__col {
    /* grow equally to fill the wall width so the columns span the full section */
    flex: 1 1 0;
    min-width: 0;
    /* each column crops its own parallax with rounded corners, so cards stay
       rounded as they scroll instead of being chopped flat by the wrapper */
    overflow: hidden;
    border-radius: 14px;
  }

  .wall__track {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    will-change: transform;
  }

  .tile {
    width: 100%;
    border-radius: 14px;
    overflow: hidden;
    background: var(--surface);
    box-shadow: 0 6px 20px rgb(0 0 0 / 7%);
  }

  .tile img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* cards dissolve into the page background at the bottom */
  .hero-wall__fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: clamp(6rem, 18vh, 12rem);
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(to bottom, transparent, var(--bg));
  }

  /* mobile single-column expandable list (replaces the parallax wall) */
  .wall-mobile {
    display: none;
    /* same gutter as the text container so cards never touch the screen edges */
    width: min(100% - 3rem, var(--container));
    margin-inline: auto;
    padding-bottom: clamp(2rem, 6vh, 4rem);
  }

  .wall-mobile__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }

  .wall-mobile__list[data-collapsed] .wall-mobile__item[data-extra='true'] {
    display: none;
  }

  .wall-mobile__item img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 14px;
    box-shadow: 0 6px 20px rgb(0 0 0 / 7%);
  }

  .wall-mobile__toggle {
    display: block;
    margin: 1.25rem auto 0;
    padding: 0.65rem 1.6rem;
    border: 1px solid rgb(0 0 0 / 14%);
    border-radius: var(--radius-pill);
    background: var(--surface);
    color: var(--ink);
    font-family: inherit;
    font-size: var(--text-small);
    font-weight: 600;
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .wall-mobile__toggle:hover {
    border-color: rgb(0 0 0 / 28%);
  }

  @media (max-width: 900px) {
    .wall__col:nth-child(n + 4) {
      display: none;
    }
  }

  /* mobile: swap the parallax wall for the single-column expandable list */
  @media (max-width: 600px) {
    .hero-wall {
      min-height: 100svh;
    }

    .wall,
    .hero-wall__fade {
      display: none;
    }

    .wall-mobile {
      display: block;
    }
  }
</style>
