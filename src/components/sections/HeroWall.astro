---
import fs from 'node:fs';

// Demo placeholder images for the wall. Drop files into public/demo-img/ and
// they are picked up automatically here. These are temporary stand-ins served
// unoptimized from public/ — replace with real, owned/licensed, optimized
// project assets (ideally via astro:assets) before launch.
const imageFiles: string[] = fs
  .readdirSync('public/demo-img')
  .filter((f: string) => /\.(png|jpe?g|webp|avif)$/i.test(f))
  .sort()
  .map((f: string) => `/demo-img/${encodeURIComponent(f)}`);

const COLUMNS = 5;

// Round-robin the images into columns, then pad short columns so every column
// overfills the viewport for the parallax to never expose an edge.
const columns: string[][] = Array.from({ length: COLUMNS }, () => []);
imageFiles.forEach((src, i) => columns[i % COLUMNS].push(src));
const minPerCol = Math.max(3, Math.ceil(imageFiles.length / COLUMNS));
columns.forEach((col, c) => {
  let i = 0;
  while (col.length < minPerCol && imageFiles.length) {
    col.push(imageFiles[(c + i) % imageFiles.length]);
    i++;
  }
});

const colMeta = Array.from({ length: COLUMNS }, (_, c) => ({
  dir: c % 2 === 0 ? 'up' : 'down',
  dist: 80 + (c % 3) * 50, // 80, 130, 180, 80, 130 — px of scroll-parallax travel
}));
---

<section class="hero-wall" id="work" aria-label="Intro">
  <div class="hero-wall__content container">
    <p class="eyebrow" data-reveal>Senior Product Designer — 9+ Years</p>
    <h1 class="hero-wall__title" data-split>
      Designing digital experiences that feel intuitive &amp; alive
    </h1>
    <p class="hero-wall__sub" data-reveal>
      Fintech · Logistics · Edu-tech · E-sport — design &amp; build
    </p>
    <a class="pill" href="#contact" data-reveal data-magnetic>Let's talk</a>
  </div>

  <div class="wall" aria-hidden="true">
    {
      columns.map((col, c) => (
        <div class="wall__col">
          <div
            class="wall__track"
            data-wall-track
            data-dir={colMeta[c].dir}
            data-dist={colMeta[c].dist}
          >
            {[...col, ...col].map((src) => (
              <div class="tile">
                <img src={src} alt="" loading="lazy" />
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Scroll-driven parallax: adjacent columns drift in opposite directions as
  // the hero scrolls past. Nothing moves at rest. Gated for reduced-motion.
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const section = document.querySelector<HTMLElement>('.hero-wall');
    if (section) {
      document.querySelectorAll<HTMLElement>('[data-wall-track]').forEach((track) => {
        const down = track.dataset.dir === 'down';
        const dist = parseFloat(track.dataset.dist || '120');
        gsap.fromTo(
          track,
          { y: 0 },
          {
            y: down ? dist : -dist,
            ease: 'none',
            scrollTrigger: {
              trigger: section,
              start: 'top top',
              end: 'bottom top',
              scrub: 1,
            },
          }
        );
      });
    }
  }
</script>

<style>
  .hero-wall {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    isolation: isolate;
  }

  .hero-wall__content {
    position: relative;
    z-index: 2;
    flex: 0 0 auto;
    display: grid;
    justify-items: center;
    text-align: center;
    gap: 1.5rem;
    padding-block: clamp(7rem, 16vh, 11rem) clamp(2.5rem, 5vh, 4rem);
  }

  .hero-wall__title {
    font-size: var(--text-display);
    max-width: 18ch;
  }

  .hero-wall__sub {
    color: var(--ink-2);
    max-width: 42ch;
  }

  .wall {
    position: relative;
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    padding-inline: 1.25rem;
    overflow: hidden;
    pointer-events: none;
    /* cards emerge from the page background at the top edge */
    -webkit-mask-image: linear-gradient(to bottom, transparent, #000 14%);
    mask-image: linear-gradient(to bottom, transparent, #000 14%);
  }

  .wall__col {
    flex: 0 0 clamp(170px, 16vw, 270px);
  }

  .wall__col:nth-child(even) {
    margin-top: -6%;
  }

  .wall__track {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    will-change: transform;
  }

  .tile {
    width: 100%;
    border-radius: 14px;
    overflow: hidden;
    background: var(--surface);
    box-shadow: 0 6px 20px rgb(0 0 0 / 7%);
  }

  .tile img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 900px) {
    .wall__col:nth-child(n + 5) {
      display: none;
    }
  }

  @media (max-width: 560px) {
    .wall__col:nth-child(n + 3) {
      display: none;
    }
  }
</style>
