---
import fs from 'node:fs';

// Demo placeholder images for the wall. Drop files into public/demo-img/ and
// they are picked up automatically here. These are temporary stand-ins served
// unoptimized from public/ — replace with real, owned/licensed, optimized
// project assets (ideally via astro:assets) before launch.
const imageFiles: string[] = fs
  .readdirSync('public/demo-img')
  .filter((f: string) => /\.(png|jpe?g|webp|avif)$/i.test(f))
  .sort()
  .map((f: string) => `/demo-img/${encodeURIComponent(f)}`);

const COLUMNS = 4;

// Round-robin the images into columns, then pad short columns so every column
// overfills the viewport for the parallax.
const columns: string[][] = Array.from({ length: COLUMNS }, () => []);
imageFiles.forEach((src, i) => columns[i % COLUMNS].push(src));
const minPerCol = Math.max(4, Math.ceil(imageFiles.length / COLUMNS) + 1);
columns.forEach((col, c) => {
  let i = 0;
  while (col.length < minPerCol && imageFiles.length) {
    col.push(imageFiles[(c + i) % imageFiles.length]);
    i++;
  }
});

const colMeta = Array.from({ length: COLUMNS }, (_, c) => ({
  dir: c % 2 === 0 ? 'up' : 'down',
  dist: 80 + (c % 3) * 50, // 80, 130, 180, 80, 130 — px of scroll-parallax travel
}));
---

<section class="hero-wall" id="work" aria-label="Intro">
  <div class="hero-wall__content">
    <div class="container hero-wall__inner">
      <p class="eyebrow" data-reveal>Senior Product Designer — 9+ Years</p>
      <h1 class="hero-wall__title" data-split>
        Designing digital experiences that feel intuitive &amp; alive
      </h1>
      <p class="hero-wall__sub" data-reveal>
        Fintech · Logistics · Edu-tech · E-sport — design &amp; build
      </p>
      <a class="pill" href="#contact" data-reveal data-magnetic>Let's talk</a>
    </div>
  </div>

  <div class="wall" aria-hidden="true">
    {
      columns.map((col, c) => (
        <div class="wall__col">
          <div
            class="wall__track"
            data-wall-track
            data-dir={colMeta[c].dir}
            data-dist={colMeta[c].dist}
          >
            {[...col, ...col].map((src) => (
              <div class="tile">
                <img src={src} alt="" loading="lazy" />
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>

  <div class="hero-wall__fade" aria-hidden="true"></div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Scroll-driven parallax: adjacent columns drift in opposite directions as
  // the hero scrolls past. Nothing moves at rest. Gated for reduced-motion.
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const section = document.querySelector<HTMLElement>('.hero-wall');
    if (section) {
      document.querySelectorAll<HTMLElement>('[data-wall-track]').forEach((track) => {
        const down = track.dataset.dir === 'down';
        const dist = parseFloat(track.dataset.dist || '120');
        gsap.fromTo(
          track,
          { y: 0 },
          {
            y: down ? dist : -dist,
            ease: 'none',
            scrollTrigger: {
              trigger: section,
              start: 'top top',
              end: 'bottom top',
              scrub: 1,
            },
          }
        );
      });
    }
  }
</script>

<style>
  .hero-wall {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    isolation: isolate;
  }

  /* Full-width opaque panel. Cards that drift up on scroll slide BEHIND this
     (occluded, not clipped) so they always keep their rounded corners. Its
     bottom edge is the even line every column starts at. */
  .hero-wall__content {
    position: relative;
    z-index: 2;
    flex: 0 0 auto;
    background: var(--bg);
    padding-block: clamp(7rem, 16vh, 11rem) clamp(2.5rem, 5vh, 4rem);
  }

  .hero-wall__inner {
    display: grid;
    justify-items: center;
    text-align: center;
    gap: 1.5rem;
  }

  .hero-wall__title {
    font-size: var(--text-display);
    max-width: 18ch;
  }

  .hero-wall__sub {
    color: var(--ink-2);
    max-width: 42ch;
  }

  .wall {
    position: relative;
    z-index: 1;
    /* flex-basis 0 so the wall fills the viewport remainder at a definite
       height instead of growing to its (tall) content — this lets every
       column stretch to the same height for one even bottom edge */
    flex: 1 1 0;
    min-height: 0;
    /* match the section container width so the wall lines up with the rest */
    width: 100%;
    max-width: var(--container);
    margin-inline: auto;
    display: flex;
    align-items: stretch;
    gap: 0.5rem;
    overflow: visible;
    pointer-events: none;
  }

  .wall__col {
    /* grow equally to fill the wall width so the columns span the full section */
    flex: 1 1 0;
    min-width: 0;
    /* each column crops its own parallax with rounded corners, so cards stay
       rounded as they scroll instead of being chopped flat by the wrapper */
    overflow: hidden;
    border-radius: 14px;
  }

  .wall__track {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    will-change: transform;
  }

  .tile {
    width: 100%;
    border-radius: 14px;
    overflow: hidden;
    background: var(--surface);
    box-shadow: 0 6px 20px rgb(0 0 0 / 7%);
  }

  .tile img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* cards dissolve into the page background at the bottom */
  .hero-wall__fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: clamp(6rem, 18vh, 12rem);
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(to bottom, transparent, var(--bg));
  }

  @media (max-width: 900px) {
    .wall__col:nth-child(n + 4) {
      display: none;
    }
  }

  @media (max-width: 700px) {
    .wall {
      padding-inline: 1.25rem;
    }
  }

  @media (max-width: 560px) {
    .wall__col:nth-child(n + 3) {
      display: none;
    }
  }
</style>
