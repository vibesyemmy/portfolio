---
// Web3Forms access key (public — it's embedded client-side). Set
// PUBLIC_WEB3FORMS_KEY in .env (and on your host). Get a free key at
// https://web3forms.com by entering your email.
const WEB3FORMS_KEY = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';

const SOCIALS = [
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/opeyemi-ajagbe/' },
  { label: 'Dribbble', href: 'https://dribbble.com/opeyemiajagbe' },
  { label: 'GitHub', href: 'https://github.com/vibesyemmy' },
  { label: 'Figma', href: 'https://www.figma.com/@opeyemiajagbe' },
  { label: 'Uxcel', href: 'https://app.uxcel.com/ux/opeyemiajagbe' },
];
---

<section class="dark-section section cta" id="contact" aria-label="Contact">
  <div class="container cta__grid">
    <!-- left: intro + who you'll be talking to -->
    <div class="cta__intro">
      <p class="eyebrow" data-reveal>Contact</p>
      <h2 class="cta__title" data-split>Let's work together</h2>
      <p class="cta__lead" data-reveal>
        Have a product, a role, or an idea you want to move on? Tell me a little
        about it and I'll get back to you within a couple of days.
      </p>

      <div class="person" data-reveal>
        <img
          class="person__avatar"
          src="/avatar.png"
          alt="Opeyemi Ajagbe"
          width="64"
          height="64"
        />
        <div>
          <p class="person__name">Opeyemi Ajagbe</p>
          <p class="person__role">Senior Product Designer</p>
        </div>
      </div>
    </div>

    <!-- right: contact form, powered by Web3Forms (POSTs to their API; they email
         submissions to you). The native POST is the no-JS fallback; the <script>
         below enhances it with an inline success/error message. -->
    <form
      class="cform"
      data-reveal
      novalidate
      action="https://api.web3forms.com/submit"
      method="POST"
    >
      <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
      <input type="hidden" name="subject" value="New enquiry from opeyemi.app" />
      <input type="hidden" name="from_name" value="opeyemi.app contact form" />
      {/* honeypot: bots tick this; Web3Forms drops those submissions */}
      <input type="checkbox" name="botcheck" class="cform__hp" tabindex="-1" autocomplete="off" aria-hidden="true" />

      {/* form body + success panel stack in one grid cell so they cross-fade
          in place — no layout jump when the confirmation takes over */}
      <div class="cform__stage">
        <div class="cform__body">
          <div class="cform__fields" data-stagger>
            <div class="field">
              <label for="cf-name">Name <span class="req">*</span></label>
              <input
                id="cf-name"
                name="name"
                type="text"
                autocomplete="name"
                placeholder="Your full name"
                required
              />
            </div>

            <div class="field">
              <label for="cf-email">Email <span class="req">*</span></label>
              <input
                id="cf-email"
                name="email"
                type="email"
                autocomplete="email"
                placeholder="Your email address"
                required
              />
            </div>

            <div class="field">
              <label for="cf-phone">Phone</label>
              <input
                id="cf-phone"
                name="phone"
                type="tel"
                autocomplete="tel"
                placeholder="Your phone number"
              />
            </div>

            <div class="field">
              <label for="cf-message">Message <span class="req">*</span></label>
              <textarea
                id="cf-message"
                name="message"
                rows="4"
                placeholder="Tell me about your project"
                required></textarea>
            </div>
          </div>

          <div class="cform__foot">
            <button class="pill pill--accent cform__submit" type="submit" data-magnetic data-state="idle">
              <span class="cform__submit-label">Send Message</span>
              <span class="cform__spinner" aria-hidden="true"></span>
            </button>
            <p class="cform__status" role="status" aria-live="polite"></p>
          </div>
        </div>

        <div class="cform__success" role="status" aria-live="polite" data-hidden>
          <span class="cform__success-badge" aria-hidden="true">
            <svg viewBox="0 0 52 52" class="cform__check">
              <circle class="cform__check-ring" cx="26" cy="26" r="23" />
              <path class="cform__check-mark" fill="none" d="M15 27 l7.5 7.5 L38 19" />
            </svg>
          </span>
          <h3 class="cform__success-title" tabindex="-1">Message sent</h3>
          <p class="cform__success-text">
            Thanks — I'll get back to you within a couple of days. Talk soon.
          </p>
          <button type="button" class="cform__again" data-magnetic>Send another →</button>
        </div>
      </div>
    </form>
  </div>

  <div class="container cta__footer">
    <nav class="socials" aria-label="Social links">
      {
        SOCIALS.map((s) => (
          <a href={s.href} target="_blank" rel="noopener noreferrer">
            {s.label}
          </a>
        ))
      }
    </nav>
    <p class="fineprint">© 2026 Opeyemi Ajagbe</p>
  </div>
</section>

<script>
  // Web3Forms AJAX submit, choreographed: button → spinner while sending, then
  // the whole form cross-fades to an animated confirmation panel. The native
  // POST stays as the no-JS fallback.
  const form = document.querySelector<HTMLFormElement>('.cform');
  const status = form?.querySelector<HTMLElement>('.cform__status');
  const submit = form?.querySelector<HTMLButtonElement>('.cform__submit');
  const body = form?.querySelector<HTMLElement>('.cform__body');
  const success = form?.querySelector<HTMLElement>('.cform__success');
  const successTitle = form?.querySelector<HTMLElement>('.cform__success-title');
  const again = form?.querySelector<HTMLButtonElement>('.cform__again');

  const setSending = (on: boolean) => {
    if (!submit) return;
    submit.dataset.state = on ? 'sending' : 'idle';
    submit.disabled = on;
  };

  const showSuccess = () => {
    body?.setAttribute('data-hidden', '');
    success?.removeAttribute('data-hidden');
    successTitle?.focus(); // land keyboard + screen-reader users on the message
  };

  const reset = () => {
    form?.reset();
    setSending(false);
    if (status) {
      status.textContent = '';
      delete status.dataset.tone;
    }
    success?.setAttribute('data-hidden', '');
    body?.removeAttribute('data-hidden');
    form?.querySelector<HTMLInputElement>('#cf-name')?.focus();
  };

  const shake = () => {
    submit?.classList.remove('is-shake');
    void submit?.offsetWidth; // reflow so the animation can replay
    submit?.classList.add('is-shake');
  };

  again?.addEventListener('click', reset);

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.reportValidity()) return;

    setSending(true);
    if (status) {
      delete status.dataset.tone;
      status.textContent = 'Sending your message…';
    }

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        headers: { Accept: 'application/json' },
        body: new FormData(form),
      });
      const data = await res.json();
      if (!data.success) throw new Error(data.message || 'Submission failed');
      setSending(false);
      if (status) status.textContent = '';
      showSuccess();
    } catch {
      setSending(false);
      if (status) {
        status.dataset.tone = 'error';
        status.textContent = 'Something went wrong — email hello@opeyemi.app instead.';
      }
      shake();
    }
  });
</script>

<style>
  .cta {
    position: relative;
    overflow: hidden;
  }

  /* soft accent glow for depth (echoes the reference's mood, in-brand orange) */
  .cta::before {
    content: '';
    position: absolute;
    left: -12%;
    bottom: -18%;
    width: 42rem;
    height: 42rem;
    background: radial-gradient(circle, rgb(251 152 38 / 9%), transparent 62%);
    pointer-events: none;
    z-index: 0;
  }

  .cta__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: clamp(2.5rem, 6vw, 6rem);
    align-items: start;
  }

  /* left column */
  .cta__intro {
    display: grid;
    gap: 1.5rem;
    align-content: start;
    max-width: 34rem;
  }

  .cta__intro .eyebrow {
    color: var(--accent);
  }

  .cta__title {
    font-size: var(--text-display);
    line-height: 1.02;
  }

  .cta__lead {
    color: var(--dark-ink-2);
    font-size: 1.0625rem;
    line-height: 1.6;
    max-width: 38ch;
  }

  .person {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .person__avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--dark-line);
    flex: 0 0 auto;
  }

  .person__name {
    font-weight: 600;
  }

  .person__role {
    color: var(--dark-ink-2);
    font-size: var(--text-small);
  }

  /* right column: form */
  .cform {
    display: grid;
    gap: 1.75rem;
  }

  .cform__fields {
    display: grid;
    gap: 1.25rem;
  }

  /* honeypot — kept out of the visual + a11y trees; bots fill it, humans don't */
  .cform__hp {
    display: none;
  }

  .field {
    display: grid;
    gap: 0.5rem;
  }

  .field label {
    font-size: var(--text-eyebrow);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--dark-ink-2);
  }

  .req {
    color: var(--accent);
  }

  .field input,
  .field textarea {
    width: 100%;
    background: var(--dark-surface);
    border: 1px solid var(--dark-line);
    border-radius: 14px;
    padding: 0.95rem 1.1rem;
    color: var(--dark-ink);
    font: inherit;
    font-size: 1rem;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .field textarea {
    resize: vertical;
    min-height: 7.5rem;
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: #6a6a6a;
  }

  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgb(251 152 38 / 18%);
  }

  .cform__foot {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .cform__submit {
    position: relative;
    border: 0;
    cursor: pointer;
    font: inherit;
    font-weight: 600;
    padding: 0.95rem 1.75rem;
  }
  .cform__submit:disabled {
    cursor: default;
  }

  /* label keeps its box (opacity, not display) so the button never resizes */
  .cform__submit-label {
    display: inline-block;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }
  .cform__submit[data-state='sending'] .cform__submit-label {
    opacity: 0;
    transform: translateY(2px);
  }

  .cform__spinner {
    position: absolute;
    inset: 0;
    width: 1.2rem;
    height: 1.2rem;
    margin: auto;
    border-radius: 50%;
    border: 2px solid rgb(0 0 0 / 22%);
    border-top-color: rgb(0 0 0 / 80%);
    opacity: 0;
    animation: cform-spin 0.7s linear infinite;
    animation-play-state: paused;
  }
  .cform__submit[data-state='sending'] .cform__spinner {
    opacity: 1;
    animation-play-state: running;
  }
  @keyframes cform-spin {
    to {
      transform: rotate(360deg);
    }
  }

  .cform__submit.is-shake {
    animation: cform-shake 0.4s ease;
  }
  @keyframes cform-shake {
    10%,
    90% {
      transform: translateX(-1px);
    }
    20%,
    80% {
      transform: translateX(2px);
    }
    30%,
    50%,
    70% {
      transform: translateX(-4px);
    }
    40%,
    60% {
      transform: translateX(4px);
    }
  }

  .cform__status {
    color: var(--dark-ink-2);
    font-size: var(--text-small);
    transition: color 0.2s ease;
  }
  .cform__status[data-tone='error'] {
    color: #ff6b5e;
  }

  /* stage: body + success share one grid cell and cross-fade in place */
  .cform__stage {
    display: grid;
  }
  .cform__body,
  .cform__success {
    grid-area: 1 / 1;
  }

  .cform__body {
    display: grid;
    gap: 1.75rem;
    transition:
      opacity 0.35s ease,
      transform 0.35s ease;
  }
  .cform__body[data-hidden] {
    opacity: 0;
    transform: scale(0.985);
    visibility: hidden;
    pointer-events: none;
  }

  .cform__success {
    display: grid;
    justify-items: start;
    align-content: center;
    gap: 0.85rem;
    transition:
      opacity 0.45s ease,
      transform 0.45s ease;
  }
  .cform__success[data-hidden] {
    opacity: 0;
    transform: translateY(10px);
    visibility: hidden;
    pointer-events: none;
  }

  .cform__success-badge {
    width: 4rem;
    height: 4rem;
  }
  .cform__success:not([data-hidden]) .cform__success-badge {
    animation: cform-pop 0.5s cubic-bezier(0.18, 0.89, 0.32, 1.28) both;
  }
  @keyframes cform-pop {
    from {
      opacity: 0;
      transform: scale(0.6);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .cform__check {
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .cform__check-ring {
    fill: rgb(251 152 38 / 12%);
    stroke: var(--accent);
    stroke-width: 2;
    stroke-dasharray: 145;
    stroke-dashoffset: 145;
  }
  .cform__check-mark {
    stroke: var(--accent);
    stroke-width: 3.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 40;
    stroke-dashoffset: 40;
  }
  .cform__success:not([data-hidden]) .cform__check-ring {
    animation: cform-draw 0.5s ease forwards;
  }
  .cform__success:not([data-hidden]) .cform__check-mark {
    animation: cform-draw 0.4s 0.35s ease forwards;
  }
  @keyframes cform-draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  .cform__success-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    letter-spacing: -0.02em;
    outline: none;
  }
  .cform__success-text {
    color: var(--dark-ink-2);
    line-height: 1.6;
    max-width: 34ch;
  }
  .cform__success:not([data-hidden]) .cform__success-title {
    animation: cform-rise 0.5s 0.15s ease both;
  }
  .cform__success:not([data-hidden]) .cform__success-text {
    animation: cform-rise 0.5s 0.25s ease both;
  }
  .cform__success:not([data-hidden]) .cform__again {
    animation: cform-rise 0.5s 0.35s ease both;
  }
  @keyframes cform-rise {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .cform__again {
    margin-top: 0.4rem;
    border: 1px solid var(--dark-line);
    background: transparent;
    color: var(--dark-ink);
    font: inherit;
    font-weight: 600;
    font-size: var(--text-small);
    padding: 0.6rem 1.1rem;
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      color 0.2s ease;
  }
  .cform__again:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  @media (prefers-reduced-motion: reduce) {
    /* keep the spinner (it conveys state); drop the decorative motion */
    .cform__submit.is-shake,
    .cform__success-badge,
    .cform__success-title,
    .cform__success-text,
    .cform__again {
      animation: none;
    }
    .cform__check-ring,
    .cform__check-mark {
      animation: none;
      stroke-dashoffset: 0;
    }
    .cform__body,
    .cform__success {
      transition: opacity 0.2s ease;
    }
  }

  /* footer row (socials + copyright) */
  .cta__footer {
    position: relative;
    z-index: 1;
    margin-top: clamp(3rem, 8vh, 6rem);
    padding-top: 2rem;
    border-top: 1px solid var(--dark-line);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .socials {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    font-size: var(--text-small);
    color: var(--dark-ink-2);
  }

  .socials a:hover {
    color: var(--dark-ink);
  }

  .fineprint {
    font-family: var(--font-mono);
    font-size: var(--text-eyebrow);
    color: var(--dark-ink-2);
  }

  @media (max-width: 880px) {
    .cta__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
