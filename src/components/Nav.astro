---
import fs from 'node:fs';

// Animated nav icons (Lordicon). Drop a Lordicon JSON export at
// public/icons/work.json / public/icons/blog.json and it's picked up
// automatically; until then the link renders as plain text (no broken state).
const hasIcon = (name: string) => fs.existsSync(`public/icons/${name}.json`);
const workIcon = hasIcon('work');
const blogIcon = hasIcon('blog');
const ICON_COLOR = '#666666'; // matches --ink-2 (the resting link colour)
---

<header class="nav-wrap">
  <nav class="nav" aria-label="Primary">
    <a class="nav__brand" href="/">Opeyemi</a>
    <div class="nav__links">
      <a class="nav__link" href="#work">
        {
          workIcon && (
            <lord-icon
              class="nav__icon"
              src="/icons/work.json"
              trigger="hover"
              target=".nav__link"
              colors={`primary:${ICON_COLOR}`}
            />
          )
        }
        <span>Work</span>
      </a>
      <a class="nav__link" href="#blog">
        {
          blogIcon && (
            <lord-icon
              class="nav__icon"
              src="/icons/blog.json"
              trigger="hover"
              target=".nav__link"
              colors={`primary:${ICON_COLOR}`}
            />
          )
        }
        <span>Blog</span>
      </a>
      <a class="pill nav__cta" href="#contact" data-magnetic>Let's Talk</a>
    </div>
  </nav>
</header>

<style>
  .nav-wrap {
    position: fixed;
    inset-inline: 0;
    top: 1rem;
    display: flex;
    justify-content: center;
    z-index: 100;
    pointer-events: none;
  }

  .nav {
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.5rem 0.5rem 0.5rem 1.5rem;
    border: 1px solid rgb(0 0 0 / 12%);
    border-radius: var(--radius-pill);
    background: rgb(255 255 255 / 75%);
    /* smaller blur kernel than the original 12px: still reads as frosted glass
       but the fixed nav re-samples a much cheaper backdrop on every scroll frame */
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 2px 8px rgb(0 0 0 / 6%);
  }

  .nav__brand {
    font-weight: 700;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    font-size: var(--text-small);
  }

  .nav__links a:not(.pill) {
    color: var(--ink-2);
    transition: color 0.2s;
  }

  .nav__links a:not(.pill):hover {
    color: var(--ink);
  }

  /* icon + label sit on one line; gap collapses to nothing when no icon */
  .nav__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .nav__icon {
    width: 1.15rem;
    height: 1.15rem;
  }

  .nav__cta {
    padding: 0.5rem 1.1rem;
  }

  @media (max-width: 480px) {
    .nav__links a:not(.pill) {
      display: none;
    }
  }
</style>
